---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <main class="container section min-h-screen flex items-center justify-center text-center">
    <div>
      <h1 class="font-display text-6xl md:text-8xl text-accent">404</h1>
      <p class="text-lg text-text-secondary mt-4">This page doesn't exist.</p>
      <a href="/" class="inline-block mt-8 px-6 py-3 bg-accent text-white rounded-lg hover:bg-accent-hover transition-colors">
        Go Home
      </a>
    </div>
  </main>
</BaseLayout>
