---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

export async function getStaticPaths() {
  const projectFiles = Object.values(
    import.meta.glob('../../content/projects/*.md', { eager: true })
  );
  return projectFiles.map((file) => ({
    params: { slug: file.frontmatter.slug },
    props: { project: file },
  }));
}

const { project } = Astro.props;
const { frontmatter, Content } = project;
const seoDescription = `${frontmatter.title} — A ${frontmatter.category.toLowerCase()} project for ${frontmatter.client}. ${frontmatter.role}.`;
---

<BaseLayout title={`${frontmatter.title} | Portfolio`} description={seoDescription}>
  <Header />
  <main class="section">
    <article class="container max-w-3xl">
      <div class="mb-8">
        <p class="text-sm tracking-widest uppercase text-accent font-medium">
          {frontmatter.category}
        </p>
        <h1 class="mt-2 font-display text-3xl md:text-4xl font-bold">
          {frontmatter.title}
        </h1>
        <div class="mt-4 flex flex-wrap gap-4 text-sm text-text-secondary">
          <span>Client: <strong class="text-text">{frontmatter.client}</strong></span>
          <span>Role: <strong class="text-text">{frontmatter.role}</strong></span>
          <span>Year: <strong class="text-text">{frontmatter.year}</strong></span>
        </div>
      </div>

      <div class="prose prose-gray dark:prose-invert max-w-none">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-border dark:border-dark-border">
        <a href="/#portfolio" class="text-accent hover:underline">&larr; Back to portfolio</a>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
