---
const CAL_COM_URL = 'https://cal.com/abdel-hakim';
---

<section id="contact" class="section reveal">
  <div class="container">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold">
        Ready to Elevate Your Brand?
      </h2>
      <p class="mt-4 text-text-secondary">
        Tell me about your project and I'll get back to you within 24 hours with a tailored proposal and estimated timeline.
      </p>
    </div>

    <form class="mt-12 max-w-xl mx-auto space-y-6" netlify name="contact" method="POST" data-netlify="true">
      <input type="hidden" name="form-name" value="contact" />

      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm font-medium mb-2">Name *</label>
          <input type="text" id="name" name="name" required
            class="w-full px-4 py-3 rounded-lg bg-surface-secondary dark:bg-dark-card border border-border dark:border-dark-border focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-2">Email *</label>
          <input type="email" id="email" name="email" required
            class="w-full px-4 py-3 rounded-lg bg-surface-secondary dark:bg-dark-card border border-border dark:border-dark-border focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors" />
        </div>
      </div>

      <div>
        <label for="project" class="block text-sm font-medium mb-2">Project Type</label>
        <select id="project" name="project"
          class="w-full px-4 py-3 rounded-lg bg-surface-secondary dark:bg-dark-card border border-border dark:border-dark-border focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors">
          <option value="">Select one</option>
          <option value="brand-identity">Brand Identity</option>
          <option value="illustration">Custom Illustration</option>
          <option value="visual-design">Visual Design</option>
          <option value="multiple">Multiple Services</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="budget" class="block text-sm font-medium mb-2">Budget Range</label>
        <select id="budget" name="budget"
          class="w-full px-4 py-3 rounded-lg bg-surface-secondary dark:bg-dark-card border border-border dark:border-dark-border focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors">
          <option value="">Select range (optional)</option>
          <option value="under-500">Under $500</option>
          <option value="500-1k">$500 – $1,000</option>
          <option value="1k-2k">$1,000 – $2,000</option>
          <option value="2k-plus">$2,000+</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium mb-2">Describe Your Project *</label>
        <textarea id="message" name="message" rows="5" required
          class="w-full px-4 py-3 rounded-lg bg-surface-secondary dark:bg-dark-card border border-border dark:border-dark-border focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors resize-none"
          placeholder="Tell me about your brand, the scope of work, your timeline, and any specific requirements..."></textarea>
      </div>

      <button type="submit"
        class="w-full px-6 py-3 bg-accent text-btn-text rounded-lg font-medium hover:bg-accent-hover transition-all duration-fast cursor-pointer active:scale-95">
        Send Inquiry
      </button>
    </form>

    <div class="mt-10 text-center">
      <p class="text-text-secondary text-sm">Prefer to book a call directly?</p>
      <a href={CAL_COM_URL} target="_blank" rel="noopener noreferrer"
        class="mt-3 inline-block px-6 py-3 border-2 border-accent text-accent rounded-lg font-medium hover:bg-accent hover:text-btn-text transition-all duration-fast active:scale-95">
        Schedule a Free Consultation
      </a>
    </div>
  </div>
</section>
