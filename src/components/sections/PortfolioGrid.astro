---
const projectFiles = Object.values(
  import.meta.glob('../../content/projects/*.md', { eager: true })
);
const projects = projectFiles.sort((a, b) => b.frontmatter.year.localeCompare(a.frontmatter.year));
---

<section id="portfolio" class="section reveal">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold">
        Featured Work
      </h2>
      <p class="mt-4 text-text-secondary">
        Every project starts with a conversation. <a href="#contact" class="text-accent font-medium hover:underline">Let's talk about yours.</a>
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-8 reveal-stagger">
      {projects.map((project) => (
        <a href={`/projects/${project.frontmatter.slug}`} class="group block rounded-2xl overflow-hidden border border-border dark:border-dark-border bg-surface dark:bg-dark-surface card-premium">
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={project.frontmatter.image}
              alt={project.frontmatter.alt || project.frontmatter.title}
              class="w-full h-full object-cover transition-transform duration-700 ease-smooth group-hover:scale-[1.08]"
              loading="lazy"
              decoding="async"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-5">
              <span class="text-white text-sm font-medium px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm translate-y-4 group-hover:translate-y-0 transition-transform duration-400">
                View Project &rarr;
              </span>
            </div>
            <!-- Category badge -->
            <span class="absolute top-3 left-3 text-[10px] uppercase tracking-widest font-medium px-2.5 py-1 rounded-full bg-surface/80 dark:bg-dark-surface/80 text-accent backdrop-blur-sm">
              {project.frontmatter.category}
            </span>
          </div>
          <div class="p-5">
            <h3 class="font-heading font-bold group-hover:text-accent transition-colors duration-fast">
              {project.frontmatter.title}
            </h3>
            <p class="mt-1 text-xs text-text-secondary">
              {project.frontmatter.year}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
