---

---

<section id="hero" class="relative min-h-screen flex items-center pt-20 pb-16 overflow-hidden">
  <!-- Background orbs -->
  <div class="absolute top-1/4 -right-1/3 w-[900px] h-[900px] rounded-full bg-gradient-to-b from-accent/15 to-secondary/5 blur-3xl pointer-events-none animate-float" aria-hidden="true"></div>
  <div class="absolute -bottom-1/2 -left-1/4 w-[700px] h-[700px] rounded-full bg-gradient-to-t from-accent/10 to-secondary/5 blur-3xl pointer-events-none animate-float-slow" aria-hidden="true"></div>

  <!-- Decorative grid lines -->
  <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05] pointer-events-none" aria-hidden="true" style="background-image: linear-gradient(var(--color-accent) 1px, transparent 1px), linear-gradient(90deg, var(--color-accent) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="container relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-center gap-12 lg:gap-20">
      <!-- Left: Text content -->
      <div class="flex-1 max-w-2xl lg:order-1">
        <p class="hero-tagline inline-block text-xs md:text-sm font-medium text-accent mb-6 tracking-[0.2em] uppercase px-4 py-1.5 rounded-full border border-accent/20 bg-accent/5">
          Graphic Designer & Illustrator
        </p>

        <h1 class="hero-heading font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold leading-[1.05]">
          <span class="block">Visuals that</span>
          <span class="block gradient-text">convert</span>
          <span class="block">audiences</span>
          <span class="block text-text-secondary font-medium">into clients</span>
        </h1>

        <p class="hero-description mt-8 text-base md:text-lg text-text-secondary max-w-lg leading-relaxed">
          I help marketing agencies, e-commerce brands, and startups turn complex ideas into clear, compelling visuals — delivered on time, on brand, and built to drive results.
        </p>

        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a href="#portfolio" class="group px-8 py-3.5 bg-accent text-btn-text rounded-full font-medium hover:bg-accent-hover transition-all duration-fast active:scale-95 inline-flex items-center gap-2">
            View Portfolio
            <svg class="w-4 h-4 transition-transform duration-fast group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="#contact" class="px-8 py-3.5 border border-border dark:border-dark-border text-text rounded-full font-medium hover:bg-accent hover:text-btn-text hover:border-accent transition-all duration-fast active:scale-95">
            Book a Call
          </a>
        </div>
      </div>

      <!-- Right: Profile image as art piece -->
      <div class="hero-image relative flex-1 flex justify-center lg:justify-end lg:order-2">
        <div class="relative">
          <!-- Main image container with floating frame -->
          <div class="relative w-72 h-72 md:w-80 md:h-80 lg:w-[28rem] lg:h-[28rem]">
            <!-- Decorative background layers -->
            <div class="absolute -top-6 -right-6 w-full h-full rounded-[2rem] bg-gradient-to-br from-accent/20 to-secondary/10 blur-2xl animate-float-slow" aria-hidden="true"></div>
            <div class="absolute -bottom-4 -left-4 w-3/4 h-3/4 rounded-[2rem] bg-gradient-to-tr from-accent/10 to-transparent blur-xl animate-float" aria-hidden="true" style="animation-delay: -6s;"></div>

            <!-- Geometric frame (octagonal clip) -->
            <div class="relative w-full h-full p-[2px] rounded-[2rem]" style="background: linear-gradient(135deg, var(--color-accent), var(--color-secondary), var(--color-accent));">
              <div class="w-full h-full rounded-[calc(2rem-2px)] overflow-hidden bg-surface dark:bg-dark-surface">
                <img
                  src="/images/projects/profile.png"
                  alt="MORAD LBOUHMADI — Graphic Designer & Illustrator"
                  class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-700"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>

            <!-- Floating geometric accent 1 -->
            <div class="absolute -top-3 -right-3 w-16 h-16 rounded-2xl bg-gradient-to-br from-secondary to-accent rotate-12 opacity-80 hidden md:block animate-float" aria-hidden="true" style="animation-delay: -3s;"></div>

            <!-- Floating geometric accent 2 -->
            <div class="absolute -bottom-2 -left-2 w-12 h-12 rounded-full bg-accent/20 border-2 border-accent/30 hidden md:block animate-float-slow" aria-hidden="true"></div>

            <!-- Decorative dots bottom-right -->
            <div class="absolute -bottom-6 -right-6 hidden md:block" aria-hidden="true">
              <svg width="64" height="64" viewBox="0 0 64 64">
                <circle cx="8" cy="8" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="24" cy="8" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="40" cy="8" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="56" cy="8" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="8" cy="24" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="24" cy="24" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="40" cy="24" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="56" cy="24" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="8" cy="40" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="24" cy="40" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="40" cy="40" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="56" cy="40" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="8" cy="56" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="24" cy="56" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="40" cy="56" r="2" fill="var(--color-accent)" opacity="0.3"/>
                <circle cx="56" cy="56" r="2" fill="var(--color-accent)" opacity="0.3"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-tagline {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 200ms forwards;
  }

  .hero-heading span {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-heading span:first-child {
    animation-delay: 350ms;
  }

  .hero-heading span:nth-child(2) {
    animation-delay: 450ms;
  }

  .hero-heading span:nth-child(3) {
    animation-delay: 550ms;
  }

  .hero-heading span:nth-child(4) {
    animation-delay: 650ms;
  }

  .hero-description {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 750ms forwards;
  }

  .hero-cta {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 900ms forwards;
  }

  .hero-image {
    opacity: 0;
    animation: fadeScaleIn 1s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeScaleIn {
    from {
      opacity: 0;
      transform: scale(0.85) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @media (max-width: 1023px) {
    .hero-image {
      animation-delay: 1.2s;
    }

    .hero-image .w-72 {
      width: 240px;
      height: 240px;
    }

    .hero-image .md\:w-80 {
      width: 240px;
      height: 240px;
    }
  }
</style>
