---

---

<section id="hero" class="relative min-h-screen flex items-center pt-20 pb-16 overflow-hidden">
  <!-- Animated gradient orbs -->
  <div class="absolute -top-1/2 -right-1/4 w-[800px] h-[800px] rounded-full bg-gradient-to-b from-accent/20 to-secondary/10 blur-3xl pointer-events-none animate-float" aria-hidden="true"></div>
  <div class="absolute -bottom-1/3 -left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-t from-accent/15 to-secondary/10 blur-3xl pointer-events-none animate-float-slow" aria-hidden="true"></div>
  <div class="absolute top-1/3 left-1/2 w-[400px] h-[400px] rounded-full bg-gradient-to-r from-accent/10 to-transparent blur-3xl pointer-events-none animate-float" aria-hidden="true" style="animation-delay: -6s;"></div>

  <div class="container relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="max-w-3xl">
        <p class="hero-tagline text-sm md:text-base font-medium text-accent mb-4 tracking-widest uppercase">
          Graphic Designer & Illustrator
        </p>

        <h1 class="hero-heading font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tight">
          <span class="block">Visuals that</span>
          <span class="block gradient-text">convert audiences</span>
          <span class="block">into clients</span>
        </h1>

        <p class="hero-description mt-6 text-lg md:text-xl text-text-secondary max-w-xl leading-relaxed">
          I help marketing agencies, e-commerce brands, and startups turn complex ideas into clear, compelling visuals — delivered on time, on brand, and built to drive results.
        </p>

        <div class="hero-cta mt-8 flex flex-wrap gap-4">
          <a href="#portfolio" class="px-6 py-3 bg-accent text-btn-text rounded-lg font-medium hover:bg-accent-hover transition-all duration-fast active:scale-95">
            View Portfolio
          </a>
          <a href="#contact" class="px-6 py-3 border border-border dark:border-dark-border text-text rounded-lg font-medium hover:bg-accent hover:text-btn-text hover:border-accent transition-all duration-fast active:scale-95">
            Book a Free Consultation
          </a>
        </div>
      </div>

      <div class="hero-image relative flex justify-center lg:justify-end mt-8 lg:mt-0">
        <div class="relative w-72 h-72 md:w-80 md:h-80 lg:w-96 lg:h-96">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/30 to-secondary/20 blur-xl animate-float-slow" aria-hidden="true"></div>
          <div class="absolute inset-2 rounded-2xl bg-gradient-to-br from-accent to-secondary p-[3px]">
            <div class="w-full h-full rounded-2xl overflow-hidden bg-surface dark:bg-dark-surface">
              <img
                src="/images/projects/profile.jpg"
                alt="MORAD LBOUHMADI — Graphic Designer & Illustrator"
                class="w-full h-full object-cover"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
          <!-- Decorative dots -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 opacity-20" aria-hidden="true">
            <div class="grid grid-cols-4 gap-2">
              {Array.from({ length: 16 }).map(() => (
                <div class="w-2 h-2 rounded-full bg-accent"></div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-tagline {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 200ms forwards;
  }

  .hero-heading span {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-heading span:first-child {
    animation-delay: 400ms;
  }

  .hero-heading span:nth-child(2) {
    animation-delay: 500ms;
  }

  .hero-heading span:last-child {
    animation-delay: 600ms;
  }

  .hero-description {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 700ms forwards;
  }

  .hero-cta {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 850ms forwards;
  }

  .hero-image {
    opacity: 0;
    animation: fadeScaleIn 800ms cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeScaleIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 1023px) {
    .hero-image {
      animation-delay: 1.2s;
    }

    .hero-image .w-72 {
      width: 200px;
      height: 200px;
    }
  }
</style>
